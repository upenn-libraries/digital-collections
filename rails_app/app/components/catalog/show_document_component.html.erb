<%# Override DocumentComponent from Blacklight v9.0.0 to
      - add Clover IIIF Viewer
      - render DocumentActions component %>

<% if document.manifest? %>
  <div class="iiif-viewer-container">
    <div class="dc-iiif-skeleton" aria-hidden="true">
      <div class="placeholder placeholder-wave dc-iiif-skeleton__stage">
        <div class="placeholder placeholder-wave dc-iiif-skeleton__asset"></div>
      </div>
      <% if render_skeleton_thumbs? %>
        <div class="dc-iiif-skeleton__thumbs">
          <% SKELETON_THUMBNAIL_COUNT.times do %>
            <div class="placeholder placeholder-wave dc-iiif-skeleton__thumb"></div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div
      data-controller="clover-viewer"
      data-clover-viewer-url-value="<%= document.manifest_url %>"
    ></div>
  </div>
<% end %>

<%= content_tag @component,
  id: @id,
  data: {
    'document-id': document.id.to_s.parameterize,
    'document-counter': counter,
  },
  itemscope: true,
  itemtype: document.itemtype,
  class: classes.flatten.join(' ') do %>
  <%= header %>
  <% if body.present? %>
    <%= body %>
  <% else %>
    <div class="document-main-section">
      <%= title %>
      <%= document_actions %>
      <%= embed %>
      <%= content %>
      <%= metadata %>
      <% metadata_sections.each do |section| %>
        <%= section %>
      <% end %>
      <% partials.each do |partial| %>
        <%= partial %>
      <% end %>
    </div>

    <%= thumbnail %>
  <% end %>
  <%= footer %>
<% end %>
