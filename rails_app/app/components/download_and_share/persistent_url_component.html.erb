<%= render(AccordionComponent.new(id: 'persistent-url')) do |accordion| %>
  <% accordion.with_header do %>
    <%= t('show.download_and_share.persistent_url.button') %>
  <% end %>

  <% accordion.with_body do %>
    <div class="d-flex gap-2 align-items-center" data-controller="clipboard">
      <%= link_to solr_document_url(@document), solr_document_url(@document), class: "flex-grow-1 text-break", "data-clipboard-target": "source" %>
      <button type="button" class="pl-button d-inline-flex gap-2 flex-nowrap text-nowrap" data-action="clipboard#copy">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" class="flex-shrink-0">
          <path d="M9 17H7C4.23858 17 2 14.7614 2 12C2 9.23858 4.23858 7 7 7H9M15 17H17C19.7614 17 22 14.7614 22 12C22 9.23858 19.7614 7 17 7H15M7 12L17 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <%= t('show.download_and_share.persistent_url.copy') %>
      </button>
    </div>
  <% end %>
<% end %>

